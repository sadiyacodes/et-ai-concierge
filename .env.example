# Environment Variables for ET AI Concierge
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key (free tier)
GOOGLE_API_KEY=

# Optional: LangSmith for tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=et-ai-concierge

# Optional: Ollama (local LLM — last resort fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Exa Search API (real-time ET content search)
# Get key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=
